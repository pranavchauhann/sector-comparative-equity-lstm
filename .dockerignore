# Keep both images lean: exclude everything not needed at container runtime.

# Version control / CI
.git/
.github/
.dvc/cache/
.dvc/tmp/

# Data & artifacts — regenerated by the pipeline into the shared volume,
# never baked into images (data/raw alone is hundreds of MB).
data/
models/
mlruns/
mlflow.db

# Local environments & caches
.venv/
venv/
__pycache__/
*.py[cod]
.ipynb_checkpoints/

# Notebooks & docs (not executed in containers)
notebooks/
*.md
DVC_SETUP.md
MLFLOW_SETUP.md
DRIFT_DETECTION.md
DOCKER_SETUP.md

# Secrets — env files must reach containers via compose `env_file`, never
# via image layers (an image layer is effectively public).
.env
.streamlit/secrets.toml

# OS / editor
.DS_Store
.vscode/
.idea/
