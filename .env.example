# Copy to `.env` (gitignored) and fill in real values. Compose feeds these
# to the training container; none are required for a plain local
# `docker compose run --rm training` (the pipeline fetches from Yahoo
# Finance and caches locally — the DVC remote is only for pull/push).

# DVC remote (optional). The gdrive folder URL, e.g. gdrive://<FOLDER_ID>
DVC_GDRIVE_URL=

# Path *inside the container* to a Google service-account JSON with access
# to that folder. Mount the file via an extra volume in docker-compose.yml,
# e.g.  - ./secrets/gdrive-sa.json:/run/secrets/gdrive-sa.json:ro
GDRIVE_SERVICE_ACCOUNT_JSON_FILE=
