# Data (raw price data is regenerable via src/data_loader.py — keep it out
# of git). `data/*` not `data/` so the exception below can apply — git never
# descends into a fully-ignored directory.
data/*
# …except the shadow prediction log (Phase 4): it is NOT regenerable — it is
# the timestamped record of what the model predicted before actuals were
# known, and the drift detectors' input. Small CSV, versioned in git.
!data/prediction_log.csv

# Python
__pycache__/
*.py[cod]
*.egg-info/
.ipynb_checkpoints/
.venv/
venv/
env/

# Trained models (regenerable; often large)
models/
*.h5
*.keras

# OS / editor
.DS_Store
.vscode/
.idea/

# Streamlit
.streamlit/secrets.toml

# MLflow local tracking store (Phase 2) — run metadata (SQLite) + logged
# artifacts. Local-only by design: DVC versions the canonical model
# artifacts, git versions the code; this is queryable experiment history
# for this machine.
mlruns/
mlflow.db

# NOTE: config/universe.json is intentionally NOT ignored — the locked,
# dated ticker universe must be version-controlled (see Non-Negotiable Rules).
# NOTE: results/ (metrics CSVs + plots) is intentionally NOT ignored — these
# are the portfolio deliverables recruiters read.
